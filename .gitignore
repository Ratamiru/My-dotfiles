# AGS node_modules (ставится через npm install)
.config/ags/node_modules/

# Кэши и временное
**/__pycache__/
**/*.pyc
**/*.pyo
.cache/

# Секреты — не коммитить!
# home/.gitconfig содержит только имя/email — ок
.config/git/credentials
home/.ssh/

